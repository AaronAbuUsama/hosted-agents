# apps/server environment — example / documentation only.
#
# Copy the keys you need into the git-ignored `apps/server/.env` (never commit real
# secrets). The orchestrator owns the live `.env`; this file documents the shape.
# Values below are placeholders unless noted.

# --- Core ---
DATABASE_URL=file:./local.db
BETTER_AUTH_SECRET=replace-with-a-32+-character-secret
BETTER_AUTH_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:3005
# Encrypts stored provider credentials at rest (optional in dev; required in prod).
AGENT_CREDENTIAL_ENCRYPTION_KEY=replace-with-a-32+-character-key
NODE_ENV=development

# --- GitHub webhooks (see docs/runbooks/local-github-webhooks.md) ---
# smee.io proxy that forwards GitHub deliveries to the local server.
GITHUB_WEBHOOK_PROXY_URL=https://smee.io/your-channel
# Shared secret configured on every GitHub App that posts to this channel.
GITHUB_WEBHOOK_SECRET=generated_or_pasted_secret

# --- Reviewer GitHub App (worker role: code_review) ---
GITHUB_APP_ID=0000000
GITHUB_APP_SLUG=your-reviewer-app-slug
# Supply the key inline OR by path (path wins for local dev).
GITHUB_APP_PRIVATE_KEY_PATH=/absolute/path/to/reviewer-app.private-key.pem
# GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
GITHUB_CLIENT_ID=your_oauth_client_id
GITHUB_CLIENT_SECRET=your_oauth_client_secret

# --- Coder GitHub App (worker role: implementation) — ADR-0001 per-role identity ---
# The Coder authors its own branches, commits, PRs, comments, and auto-merges.
GITHUB_CODER_APP_ID=0000000
GITHUB_CODER_APP_SLUG=your-coder-app-slug
GITHUB_CODER_APP_PRIVATE_KEY_PATH=/absolute/path/to/coder-app.private-key.pem
# GITHUB_CODER_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"

# --- C7 auto-merge allow-list ---
# Exact `owner/name` repositories the Coder may squash-merge on an approved review.
# Comma-/whitespace-separated; case-insensitive. UNSET or EMPTY means NOTHING
# auto-merges — every approved Coder PR only gets a "ready to merge" comment. Set
# this ONLY for repositories where autonomous merge is intended.
#
# Ships (overnight run) = the proof repo only:
CODER_AUTOMERGE_REPOS=AaronAbuUsama/test-repo

# --- Daytona (write-capable sandbox runner) ---
DAYTONA_API_KEY=your_daytona_api_key
# DAYTONA_API_URL=https://your-daytona-host

# --- Optional observability ---
# SENTRY_DSN=
# SENTRY_ENVIRONMENT=
# SENTRY_RELEASE=
# BRAINTRUST_API_KEY=
# BRAINTRUST_PROJECT_NAME=
