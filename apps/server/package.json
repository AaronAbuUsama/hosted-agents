{
  "name": "server",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "build": "flue build --target node",
    "check-types": "tsc -b",
    "compile": "bun build --compile --minify --sourcemap --bytecode ./src/index.ts --outfile server",
    "dev": "NODE_OPTIONS='--import braintrust/hook.mjs' flue dev --target node --port 3000",
    "start": "node --import braintrust/hook.mjs dist/server.mjs",
    "worker:code-reviews": "NODE_OPTIONS='--import braintrust/hook.mjs' bun src/workers/code-review-worker.ts"
  },
  "dependencies": {
    "@daytona/sdk": "^0.187.0",
    "@earendil-works/pi-ai": "^0.80.3",
    "@flue/github": "1.0.0-beta.1",
    "@flue/runtime": "^1.0.0-beta.9",
    "@hosted-agents/api": "workspace:*",
    "@hosted-agents/auth": "workspace:*",
    "@hosted-agents/db": "workspace:*",
    "@hosted-agents/env": "workspace:*",
    "@octokit/rest": "^22.0.1",
    "@orpc/openapi": "catalog:",
    "@orpc/server": "catalog:",
    "@orpc/zod": "catalog:",
    "@sentry/node": "^10.53.1",
    "better-auth": "catalog:",
    "braintrust": "3.20.0",
    "dotenv": "catalog:",
    "drizzle-orm": "^0.45.2",
    "hono": "catalog:",
    "valibot": "^1.4.2",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@flue/cli": "^1.0.0-beta.9",
    "@hosted-agents/config": "workspace:*",
    "@types/bun": "catalog:",
    "tsdown": "^0.22.3",
    "typescript": "catalog:"
  }
}
